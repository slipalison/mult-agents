# LangSmith - Tracing e observabilidade (opcional)
# Crie sua chave em: https://smith.langchain.com/settings
#
# Para ativar: copie este arquivo para .env e preencha a chave.
# O tracing captura automaticamente todos os nos do grafo:
#   planner -> coder -> writer -> reviewer
#
# Para instalar as dependencias:
#   pip install -r requirements.txt

LANGSMITH_API_KEY=ls__sua_chave_aqui
LANGSMITH_PROJECT=like_claude
